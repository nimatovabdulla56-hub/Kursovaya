<Window x:Class="DPSApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DPSApp"
        mc:Ignorable="d"
        Title="Учет: Салон сотовой связи" Height="700" Width="1200"
        Background="#F4F7F9" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель меню -->
        <Border Background="#2C3E50" Grid.Column="0">
            <StackPanel Margin="10">
                <TextBlock Text="САЛОН СВЯЗИ" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,10,0,20" HorizontalAlignment="Center"/>

                <ListBox x:Name="MenuList" Background="Transparent" BorderThickness="0" 
                         SelectionChanged="MenuList_SelectionChanged" AlternationCount="1">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3498DB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Resources>

                    <!-- Важно: Tag должен точно совпадать с именем таблицы в SQL -->
                    <ListBoxItem Content="👥 Клиенты" Tag="Клиенты"/>
                    <ListBoxItem Content="📱 SIM-карты" Tag="SIMКарты"/>
                    <ListBoxItem Content="💳 Тарифы" Tag="Тарифы"/>
                    <ListBoxItem Content="📞 Модели телефонов" Tag="МоделиТелефонов"/>
                    <ListBoxItem Content="🏢 Бренды" Tag="Бренды"/>
                    <ListBoxItem Content="💰 Продажи" Tag="ПродажиТелефонов"/>
                    <ListBoxItem Content="📝 Подписки" Tag="Подписки"/>
                    <ListBoxItem Content="👨‍💼 Сотрудники" Tag="Сотрудники"/>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Правая панель контента -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TxtTableName" Text="Выберите таблицу из списка" FontSize="24" FontWeight="Light" Margin="0,0,0,20" Foreground="#2C3E50"/>

            <DataGrid x:Name="MainDataGrid" Grid.Row="1" 
                      AutoGenerateColumns="True" 
                      CanUserAddRows="False"
                      Background="White"
                      AlternatingRowBackground="#F9F9F9"
                      RowHeight="35"
                      FontSize="13"
                      BorderBrush="#DCDDE1"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Добавить" Click="BtnAdd_Click" Width="120" Height="35" Margin="5" Background="#27AE60" Foreground="White"/>
                <Button Content="Удалить" Click="BtnDelete_Click" Width="120" Height="35" Margin="5" Background="#E74C3C" Foreground="White"/>
                <Button Content="Сохранить" Click="BtnRefresh_Click" Width="120" Height="35" Margin="5" Background="#3498DB" Foreground="White"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
